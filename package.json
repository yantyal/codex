    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
