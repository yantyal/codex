{
  "name": "codex",
  "version": "1.4.0",
  "description": "",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.build.json && npm run build --workspaces --if-present",
    "start": "npm run build && node dist/server.js",
    "start:prod": "node dist/server.js",
    "test": "jest && npm run test --workspaces --if-present",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "format": "prettier \"**/*.{js,mjs,ts,json,md,yaml}\" --write",
    "format:check": "prettier \"**/*.{js,mjs,ts,json,md,yaml}\" --check",
    "audit": "npm audit --audit-level=high",
    "redmine:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-redmine.ps1",
    "redmine:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-redmine.ps1",
    "redmine:mcp:build": "npm --prefix tools/redmine-mcp run build",
    "redmine:mcp:test": "npm --prefix tools/redmine-mcp run check",
    "redmine:mcp:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-redmine-mcp.ps1",
    "redmine:import:mvp": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/import-redmine-mvp.ps1",
    "db:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-app-databases.ps1",
    "db:test:migrations": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-app-migrations.ps1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "CommonJS",
            "moduleResolution": "Node",
            "ignoreDeprecations": "6.0"
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/tools/",
      "<rootDir>/apps/web/"
    ]
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.39.4",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
