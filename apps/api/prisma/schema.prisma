generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id              String                 @id @db.Char(36)
  name            String                 @db.VarChar(100)
  email           String                 @unique @db.VarChar(255)
  passwordHash    String                 @map("password_hash") @db.VarChar(255)
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  deletedAt       DateTime?              @map("deleted_at")
  skillCategories SkillCategory[]
  skillLevels     SkillLevelDefinition[]
  sessions        Session[]
  auditLogs       AuditLog[]
  careerGoals     CareerGoal[]

  @@map("users")
}

model CareerGoal {
  id           String    @id @db.Char(36)
  userId       String    @map("user_id") @db.Char(36)
  name         String    @db.VarChar(200)
  targetRole   String    @map("target_role") @db.VarChar(200)
  dueDate      DateTime  @map("due_date") @db.Date
  reason       String    @db.Text
  currentState String    @map("current_state") @db.Text
  targetState  String    @map("target_state") @db.Text
  priority     String    @db.VarChar(20)
  status       String    @db.VarChar(20)
  archivedAt   DateTime? @map("archived_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, dueDate])
  @@map("career_goals")
}

model AuditLog {
  id           String   @id @db.Char(36)
  actorUserId  String   @map("actor_user_id") @db.Char(36)
  action       String   @db.VarChar(20)
  resourceType String   @map("resource_type") @db.VarChar(100)
  resourceId   String   @map("resource_id") @db.VarChar(100)
  outcome      String   @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  actor        User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId, createdAt])
  @@index([resourceType, resourceId, createdAt])
  @@map("audit_logs")
}

model Session {
  tokenHash     String   @id @map("token_hash") @db.Char(64)
  userId        String   @map("user_id") @db.Char(36)
  csrfTokenHash String   @map("csrf_token_hash") @db.Char(64)
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model SkillCategory {
  id           String   @id @db.Char(36)
  userId       String   @map("user_id") @db.Char(36)
  name         String   @db.VarChar(100)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, isActive, displayOrder])
  @@map("skill_categories")
}

model SkillLevelDefinition {
  id          String   @id @db.Char(36)
  userId      String   @map("user_id") @db.Char(36)
  level       Int
  name        String   @db.VarChar(100)
  description String   @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, level])
  @@index([userId])
  @@map("skill_level_definitions")
}
