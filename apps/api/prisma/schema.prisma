generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id              String                 @id @db.Char(36)
  name            String                 @db.VarChar(100)
  email           String                 @unique @db.VarChar(255)
  passwordHash    String                 @map("password_hash") @db.VarChar(255)
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  deletedAt       DateTime?              @map("deleted_at")
  skillCategories SkillCategory[]
  skillLevels     SkillLevelDefinition[]
  sessions        Session[]
  auditLogs       AuditLog[]
  careerGoals     CareerGoal[]
  skills          Skill[]
  roadmapItems    RoadmapItem[]

  @@map("users")
}

model Skill {
  id           String            @id @db.Char(36)
  userId       String            @map("user_id") @db.Char(36)
  categoryId   String            @map("category_id") @db.Char(36)
  name         String            @db.VarChar(200)
  currentLevel Int               @map("current_level")
  targetLevel  Int               @map("target_level")
  criteria     String            @db.Text
  notes        String            @db.Text
  archivedAt   DateTime?         @map("archived_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     SkillCategory     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  careerGoals  CareerGoalSkill[]
  roadmapItems RoadmapItem[]

  @@unique([userId, categoryId, name])
  @@index([userId, currentLevel, targetLevel])
  @@map("skills")
}

model CareerGoal {
  id             String            @id @db.Char(36)
  userId         String            @map("user_id") @db.Char(36)
  name           String            @db.VarChar(200)
  targetRole     String            @map("target_role") @db.VarChar(200)
  dueDate        DateTime          @map("due_date") @db.Date
  reason         String            @db.Text
  currentState   String            @map("current_state") @db.Text
  targetState    String            @map("target_state") @db.Text
  priority       String            @db.VarChar(20)
  status         String            @db.VarChar(20)
  archivedAt     DateTime?         @map("archived_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  requiredSkills CareerGoalSkill[]
  roadmapItems   RoadmapItem[]

  @@index([userId, status, dueDate])
  @@map("career_goals")
}

model RoadmapItem {
  id               String              @id @db.Char(36)
  userId           String              @map("user_id") @db.Char(36)
  careerGoalId     String              @map("career_goal_id") @db.Char(36)
  skillId          String?             @map("skill_id") @db.Char(36)
  name             String              @db.VarChar(200)
  plannedStartDate DateTime            @map("planned_start_date") @db.Date
  plannedEndDate   DateTime            @map("planned_end_date") @db.Date
  sortOrder        Int                 @default(0) @map("sort_order")
  priority         String              @db.VarChar(20)
  status           String              @db.VarChar(20)
  progressRate     Int                 @default(0) @map("progress_rate")
  archivedAt       DateTime?           @map("archived_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerGoal       CareerGoal          @relation(fields: [careerGoalId], references: [id], onDelete: Cascade)
  skill            Skill?              @relation(fields: [skillId], references: [id], onDelete: SetNull)
  prerequisites    RoadmapDependency[] @relation("RoadmapDependencyTarget")
  dependents       RoadmapDependency[] @relation("RoadmapDependencyPrerequisite")

  @@index([userId, plannedStartDate, sortOrder])
  @@index([careerGoalId])
  @@index([skillId])
  @@map("roadmap_items")
}

model RoadmapDependency {
  roadmapItemId      String      @map("roadmap_item_id") @db.Char(36)
  prerequisiteItemId String      @map("prerequisite_item_id") @db.Char(36)
  createdAt          DateTime    @default(now()) @map("created_at")
  roadmapItem        RoadmapItem @relation("RoadmapDependencyTarget", fields: [roadmapItemId], references: [id], onDelete: Cascade)
  prerequisiteItem   RoadmapItem @relation("RoadmapDependencyPrerequisite", fields: [prerequisiteItemId], references: [id], onDelete: Cascade)

  @@id([roadmapItemId, prerequisiteItemId])
  @@index([prerequisiteItemId])
  @@map("roadmap_dependencies")
}

model CareerGoalSkill {
  careerGoalId String     @map("career_goal_id") @db.Char(36)
  skillId      String     @map("skill_id") @db.Char(36)
  createdAt    DateTime   @default(now()) @map("created_at")
  careerGoal   CareerGoal @relation(fields: [careerGoalId], references: [id], onDelete: Cascade)
  skill        Skill      @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@id([careerGoalId, skillId])
  @@index([skillId])
  @@map("career_goal_skills")
}

model AuditLog {
  id           String   @id @db.Char(36)
  actorUserId  String   @map("actor_user_id") @db.Char(36)
  action       String   @db.VarChar(20)
  resourceType String   @map("resource_type") @db.VarChar(100)
  resourceId   String   @map("resource_id") @db.VarChar(100)
  outcome      String   @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  actor        User     @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId, createdAt])
  @@index([resourceType, resourceId, createdAt])
  @@map("audit_logs")
}

model Session {
  tokenHash     String   @id @map("token_hash") @db.Char(64)
  userId        String   @map("user_id") @db.Char(36)
  csrfTokenHash String   @map("csrf_token_hash") @db.Char(64)
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model SkillCategory {
  id           String   @id @db.Char(36)
  userId       String   @map("user_id") @db.Char(36)
  name         String   @db.VarChar(100)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills       Skill[]

  @@unique([userId, name])
  @@index([userId, isActive, displayOrder])
  @@map("skill_categories")
}

model SkillLevelDefinition {
  id          String   @id @db.Char(36)
  userId      String   @map("user_id") @db.Char(36)
  level       Int
  name        String   @db.VarChar(100)
  description String   @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, level])
  @@index([userId])
  @@map("skill_level_definitions")
}
